# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── Service Identity ───────────────────────────────────────────────────────────
PROJECT_REVIEW_API_URL=https://project-reviewer-v3.onrender.com/api

PROJECT_REVIEW_TIMEOUT_MS=900000

# ── Internal JWT Auth (microservice-to-microservice) ──────────────────────────
PROJECT_REVIEW_INTERNAL_AUTH_ENABLED=true
PROJECT_REVIEW_INTERNAL_AUTH_ISSUER=main-backend
PROJECT_REVIEW_INTERNAL_AUTH_AUDIENCE=microservice
PROJECT_REVIEW_INTERNAL_AUTH_EXPIRES_IN=24h
PROJECT_REVIEW_INTERNAL_AUTH_ALGORITHM=HS256
PROJECT_REVIEW_INTERNAL_AUTH_JWT_SECRET=replace-with-a-very-long-random-internal-secret
PROJECT_REVIEW_INTERNAL_AUTH_REQUIRED_SERVICE=main-backend

# ── API Rate Limit ────────────────────────────────────────────────────────────
API_RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
REDIS_URL=redis://localhost:6379/0
REDIS_UR=redis://localhost:6379/0

# ── Review Worker ─────────────────────────────────────────────────────────────
# Uses Postgres-backed review_job_events as the durable queue.
REVIEW_WORKER_ENABLED=true
REVIEW_WORKER_POLL_SECONDS=3
REVIEW_WORKER_STALE_SECONDS=1800



# ── Databases ──────────────────────────────────────────────────────────────────
# Runtime DB permissions should be SELECT + INSERT only. Create/migrate schema
# outside this service with db/schema.sql or your migration system.
DATABASE_URL=postgresql+asyncpg://user:password@host/db

# For local development, run:
#   python script/setup.py
# It starts isolated local Postgres/Redis containers and rewrites DATABASE_URL,
# REDIS_URL, and REDIS_UR to localhost so developers do not hit deployed DBs.
